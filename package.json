{
  "name": "running-average",
  "version": "2.0.3",
  "description": "Memory-efficient module that tracks the current average value of an unlimited series of numbers",
  "homepage": "https://github.com/nfriedly/running-average",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nfriedly/running-average.git"
  },
  "author": {
    "name": "Nathan Friedly",
    "url": "http://nfriedly.com/"
  },
  "type": "module",
  "module": "./lib/running-average.js",
  "files": [
    "lib"
  ],
  "keywords": [
    "average",
    "running",
    "window",
    "mean",
    "arithmetic",
    "sliding",
    "moving"
  ],
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "pretty-quick": "^4.2.2"
  },
  "scripts": {
    "test": "npm run lint && npm run unit-test",
    "lint": "eslint .",
    "autofix": "eslint . --fix",
    "unit-test": "node --experimental-vm-modules node_modules/jest/bin/jest.js"
  },
  "husky": {
    "hooks": {
      "pre-commit": "pretty-quick --staged"
    }
  },
  "license": "MIT"
}
